DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# Database: default is SQLite unless you set DB_ENGINE=postgres
DB_ENGINE=sqlite

# If using Postgres:
# DB_ENGINE=postgres
# POSTGRES_DB=smartwardrobe
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# FastAPI / ML service base URL
ML_SERVICE_URL=http://localhost:8001
ML_RETRAIN_RATINGS_THRESHOLD=50

# JWT settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
